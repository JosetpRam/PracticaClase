<UserControl x:Class="PracticaClase.Uscontrol.CardAsignatura"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PracticaClase.Uscontrol"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Border BorderBrush="Black" BorderThickness="1" Margin="25,23,25,23" Grid.ColumnSpan="2">
        <StackPanel Margin="40,35,40,35">
            <TextBlock Text="{Binding Nombre}" Height="16" FontSize="12" FontWeight="Bold"/>
            <TextBlock Text="{Binding Descripcion, RelativeSource={RelativeSource AncestorType=UserControl}}" Height="16" FontWeight="Bold"/>
            <TextBlock Text="{Binding Carreras, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" Height="16" FontWeight="Bold" FontSize="12"/>
        </StackPanel>
    </Border>
</UserControl>
