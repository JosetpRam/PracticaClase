<Window x:Class="PracticaClase.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:control="clr-namespace:PracticaClase.Uscontrol"
        mc:Ignorable="d"
        Title="Clases" Height="450" Width="800">
    <Grid Background="#FF446FE2">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0">
            <ItemsControl>
                <control:Menucontrol/>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="1"
         Content="MOSTRAR"
         Margin="0,15,0,15"
         HorizontalAlignment="Center" Command="{Binding GetAllCommand}" Background="#FF5AEE1E" FontWeight="Bold"/>
        <Grid Margin="227,0,0,0" Background="White">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="550*"/>
                <ColumnDefinition Width="23*"/>
            </Grid.ColumnDefinitions>
            <Border BorderBrush="Black" BorderThickness="1" Margin="-225,0,551,380"/>
            <TextBlock HorizontalAlignment="Left" Margin="-206,18,0,0" TextWrapping="Wrap" Text="Inicio" VerticalAlignment="Top" Height="18" Width="93" Foreground="White" FontSize="14" FontFamily="Arial Black"/>

        </Grid>
        <control:Menucontrol HorizontalAlignment="Left" Margin="0,46,0,0" VerticalAlignment="Top" Width="227" Height="338"/>
        <Label Content="Proyectos" HorizontalAlignment="Left" Margin="29,66,0,0" VerticalAlignment="Top" Width="139" Foreground="White" FontFamily="Arial Black" FontSize="14"/>
        <Label Content="Tareas" HorizontalAlignment="Left" Margin="29,115,0,0" VerticalAlignment="Top" Width="139" FontFamily="Arial Black" Foreground="White" FontSize="14"/>
        <Label Content="Reportes" HorizontalAlignment="Left" Margin="29,174,0,0" VerticalAlignment="Top" Width="139" FontFamily="Arial Black" FontSize="14" Foreground="White"/>
        <Label Content="Calendario" HorizontalAlignment="Left" Margin="29,217,0,0" VerticalAlignment="Top" Width="139" FontFamily="Arial Black" Foreground="#FFFFFEFE" FontSize="14"/>
        <Label Content="Usuario" HorizontalAlignment="Left" Margin="29,276,0,0" VerticalAlignment="Top" Width="139" FontFamily="Arial Black" FontSize="14" Foreground="White"/>
        <Label Content="Configuracion" HorizontalAlignment="Left" Margin="29,328,0,0" VerticalAlignment="Top" Foreground="White" FontFamily="Arial Black" FontSize="14"/>
    </Grid>
</Window>
